{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "z-fleet",
  "version-string": "0.1.0",
  "description": "Lightweight endpoint probe and management framework.",
  "dependencies": [
    "boost-asio",
    "boost-beast",
    "boost-filesystem",
    "boost-process",
    "boost-uuid",
    "cli11",
    "nlohmann-json",
    "nghttp2",
    "openssl",
    "protobuf",
    "zlib",
    "spdlog",
    "sqlite3",
    "sqlitecpp",
    "tomlplusplus"
  ],
  "features": {
    "tests": {
      "description": "Dependencies required when building the test suite.",
      "dependencies": [
        "catch2"
      ]
    }
  }
}
